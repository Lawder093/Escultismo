<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Centros de Desarrollo</title>

<style>

/* SECCIÓN */

.seccion-centros-ola{
  padding:60px 20px;
  text-align:center;
}

/* TÍTULO */

.titulo-ola{
  font-size:2rem;
  margin-bottom:40px;
}

/* GRID */

.grid-centros-rebote{
  display:grid;
  grid-template-columns:repeat(auto-fit, minmax(150px,1fr));
  gap:40px;
  max-width:700px;
  margin:auto;
  align-items:center;
}

/* LOGOS */

.logo-rebote{
  max-width:150px;
  height:auto;
}

.grid-centros-rebote a{
  text-decoration:none;
}

</style>

</head>

<body>

<section class="seccion-centros-ola">
  <h2 class="titulo-ola">Centros de Desarrollo Permanentes</h2>

  <div class="grid-centros-rebote">

    <a href="/centros/huehuetl">
      <img 
      src="https://escultista.org/wp-content/uploads/2023/11/meraki-color.png"
      class="logo-rebote"
      alt="Centro Huehuetl">
    </a>

    <a href="/centros/gip">
      <img 
      src="https://escultista.org/wp-content/uploads/2025/05/GIP-208x300-1.png"
      class="logo-rebote"
      alt="Centro Scout">
    </a>

    <a href="/centros/san-lucas">
      <img 
      src="https://escultista.org/wp-content/uploads/2023/10/CDS-e1677955566360-150x150-1.png"
      class="logo-rebote"
      alt="Centro San Lucas">
    </a>

  </div>
</section>

</body>
</html>